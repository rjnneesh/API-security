# Server Configuration
PORT=5001
NODE_ENV=development

# Deployment URLs
FRONTEND_URL=https://api-security-five.vercel.app
BACKEND_URL=https://api-security-5q8p.onrender.com
# Optional: comma-separated extra allowed origins for CORS
# CORS_ORIGINS=http://localhost:5173,https://staging.example.com

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/api_sentinel

# JWT Secret (change this to a long random string in production!)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_2024
JWT_EXPIRE=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Anomaly Detection Thresholds
REQUESTS_PER_MINUTE_THRESHOLD=30
FAILED_LOGIN_THRESHOLD=5
BLOCK_DURATION_MINUTES=30
